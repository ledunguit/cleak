# macOS
.DS_Store

# Workspace-local envs and caches
.env
.env.*
!.env.example
.venv/
venv/
node_modules/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editors
.idea/
.vscode/

# Top-level office and paper artifacts
/*.pdf
/*.doc
/*.docx
/*.ppt
/*.pptx

# Logs and temp artifacts
*.log
tmp/
temp/

# Build outputs and caches
/dist/
/output/
/coverage/
/apps/leak-inspector-ui/dist/
/.turbo/
/apps/leak-inspector-ui/node_modules/

# Scan/eval outputs (generated) anywhere in the tree
**/results/

# Benchmark archives + ingested corpora (regenerate via scripts/juliet/ingest.ts)
/juliet.zip
*.zip
/demo/juliet_cwe401/

# Real-project corpus: materialized cases + cloned repos are regenerable via
# scripts/real-projects/ingest.ts; only ground-truth.json is committed (the source).
/demo/real_projects/cases/
/demo/real_projects/.clones/
/demo/real_projects/corpus_manifest.json

# Compiled demo-corpus binaries (rebuild from source via each case's Makefile)
/demo/memory_leak_corpus/*/array_leak
/demo/memory_leak_corpus/*/array_leak_*
/demo/memory_leak_corpus/*/ownership_maze
/demo/memory_leak_corpus/*/use_after_free
/demo/**/a.out

# User-provided scan targets
/targets/*
!/targets/.gitkeep

# Generated demo corpus build artifacts
/demo/**/compilation.json
/demo/**/compile_commands.json
/demo/**/build/
/demo/**/simple_leak
/demo/**/simple_leak_asan

.antigravitycli

vendor
