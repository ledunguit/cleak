# MCP-Vul application
MEMORY_LEAK_APP_HOST=0.0.0.0
MEMORY_LEAK_APP_PORT=8090
MEMORY_LEAK_APP_WORKSPACE_ROOTS=/workspace/demo/memory_leak_corpus:/workspace/targets
MEMORY_LEAK_APP_ARTIFACT_DIR=/workspace/results/app_scans
MEMORY_LEAK_APP_DB_PATH=/workspace/results/app_scans/memory_leak_app.sqlite3
THESIS_TARGETS_HOST_DIR=./targets

# MCP servers, when running inside docker-compose.thesis-demo.yml
MCP_STATIC_SERVER_URL=http://host.docker.internal:8081/mcp
MCP_DYNAMIC_SERVER_URL=http://host.docker.internal:8080/mcp

# Local host defaults, useful when running scripts/run_memory_leak_app.sh
# MCP_STATIC_SERVER_URL=http://localhost:8081/mcp
# MCP_DYNAMIC_SERVER_URL=http://localhost:8080/mcp
# MEMORY_LEAK_APP_WORKSPACE_ROOTS=./demo/memory_leak_corpus:./targets
# MEMORY_LEAK_APP_ARTIFACT_DIR=./results/app_scans
# THESIS_TARGETS_HOST_DIR=./targets

# Optional judge configuration
MEMORY_LEAK_JUDGE_MODE=heuristic
MEMORY_LEAK_JUDGE_BATCH_SIZE=8
MEMORY_LEAK_JUDGE_SCOPE=selective
MEMORY_LEAK_STATIC_EXPANSION_MODE=balanced
MEMORY_LEAK_FILE_ANALYSIS_CONCURRENCY=4
MEMORY_LEAK_STATIC_TOOL_CONCURRENCY=3
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
LLM_PROVIDER=local
LOCAL_LLM_BASE_URL=http://host.docker.internal:20128/v1
LOCAL_LLM_MODEL=gh/gpt-5-mini
LOCAL_LLM_API_KEY=sk_9router

# LeakGuard static tool container settings
LEAKGUARD_DOCKER_IMAGE=leakguard-tool:dev
LEAKGUARD_DOCKER_PLATFORM=linux/amd64
