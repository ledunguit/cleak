# ── Thesis workspace · env định hướng ────────────────────────────────────────
# master là TUI-only. Mỗi project có .env.example riêng — copy thành .env và điền:
#
#   apps/static-analyzer/.env.example      → apps/static-analyzer/.env
#   apps/dynamic-analyzer/.env.example     → apps/dynamic-analyzer/.env
#   apps/leak-inspector-tui/.env.example   → apps/leak-inspector-tui/.env
#
# docker-compose nạp .env của TỪNG container qua `env_file` (xem docker-compose.yml).
# `.gitignore` đã bỏ qua mọi .env và chỉ commit .env.example.

# ── LLM config dùng chung (TUỲ CHỌN ở đây) ───────────────────────────────────
# leak-inspector-tui đọc CẢ file này LẪN apps/leak-inspector-tui/.env, nên có thể đặt
# cấu hình LLM ở đây để dùng một .env duy nhất ở root. Chi tiết mọi biến: xem
# apps/leak-inspector-tui/.env.example.
# LLM_PROVIDER=local
# LOCAL_LLM_BASE_URL=http://localhost:20128/v1
# LOCAL_LLM_API_KEY=
# LOCAL_LLM_MODEL=mimo/mimo-v2.5-pro
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Ghi chú ───────────────────────────────────────────────────────────────────
# EXTRA_ALLOCATOR_NAMES giờ thuộc apps/static-analyzer/.env (không còn nội suy ở root).
