# ── static-analyzer (NestJS · MCP/HTTP) ──────────────────────────────────────
# Phân tích tĩnh C/C++; chỉ phục vụ MCP/HTTP (leak-inspector-tui điều phối qua MCP).
# Copy file này thành `.env` rồi chỉnh nếu cần. MỌI biến đều TUỲ CHỌN — bỏ trống thì
# code dùng default. Trong Docker, các biến này được nạp qua `env_file` của service;
# chạy trên host (turbo dev) thì main.ts tự nạp apps/static-analyzer/.env.

# Cổng MCP/HTTP server. Mặc định 50061. Đổi thì nhớ sửa cả `ports:` trong docker-compose.yml.
MCP_HTTP_PORT=50061

# Thư mục lưu báo cáo scan-build (Clang Static Analyzer). Mặc định ./runs.
RUNS_DIR=./runs

# Đường dẫn binary scan-build (Clang Static Analyzer). Mặc định lấy `scan-build` trong PATH.
SCAN_BUILD_BIN=scan-build

# Tên hàm allocator tuỳ dự án, ngăn cách bằng dấu phẩy — mở rộng tập nhận diện cấp phát
# ngoài malloc/calloc/realloc/strdup/new (vd: "my_alloc,xmalloc,pool_new"). Mặc định rỗng.
# (Tương đương AllocSource của LAMeD cho các wrapper allocator theo dự án.)
EXTRA_ALLOCATOR_NAMES=
