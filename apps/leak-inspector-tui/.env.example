# ── leak-inspector-tui / @cleak/cli (orchestrator, chạy trên HOST) ────────────
# Scanner agentic điều phối 2 analyzer qua MCP/HTTP. Copy file này thành `.env`
# (cùng thư mục) rồi điền key. TUI tự nạp từ <repo-root>/.env HOẶC
# apps/leak-inspector-tui/.env. MỌI biến TUỲ CHỌN trừ key của provider bạn chọn.
#
# Khi cài global (npm i -g @cleak/cli) có thể dùng config file THAY cho env:
#   cleak config set staticUrl http://…   ·   cleak config init   (~/.config/cleak/config.json)
# Ưu tiên: CLI flag > biến env (gồm file .env này) > config file > default.

# ── LLM provider ──────────────────────────────────────────────────────────────
# local | openai | anthropic | openai-compat
LLM_PROVIDER=local

# Provider = local: gateway OpenAI-compatible cục bộ (vLLM/Ollama/LM Studio/…)
LOCAL_LLM_BASE_URL=http://localhost:20128/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=mimo/mimo-v2.5-pro
LOCAL_LLM_JSON_MODE=true

# Provider = openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# OPENAI_JSON_MODE=true

# Provider = anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Provider = openai-compat (endpoint OpenAI-compatible bất kỳ — cả 3 biến bắt buộc)
# OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=
# OPENAI_COMPAT_JSON_MODE=true

# ── Endpoint analyzer (MCP/HTTP) ──────────────────────────────────────────────
STATIC_ANALYZER_MCP_URL=http://localhost:50061/mcp
DYNAMIC_ANALYZER_MCP_URL=http://localhost:50062/mcp
# Ánh xạ path host ↔ path mà analyzer (trong container) nhìn thấy. Đặt khi quét code
# nằm ngoài các volume đã mount sẵn (demo/, targets/). CLI: --host-root / --analyzer-root.
# HOST_ROOT=
# ANALYZER_ROOT=
# Đặt =1 nếu CHÍNH TUI cũng chạy trong container (giữ host.docker.internal, không rewrite localhost).
# IN_CONTAINER=

# ── Hành vi scan / LLM (tuỳ chỉnh nâng cao) ───────────────────────────────────
# RESULTS_DIR=results            # thư mục xuất report results/<scanId>/
# AGENT_MAX_TURNS=15             # ngân sách lượt cho pha investigation (1–200)
# LLM_TIMEOUT_MS=75000
# LLM_IDLE_TIMEOUT_MS=75000      # im lặng giữa các chunk stream quá lâu ⇒ coi như treo
# LLM_CONNECT_TIMEOUT_MS=30000
# LLM_RETRIES=2
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0              # 0 = tái lập được
# JUDGE_LLM_TEMPERATURE=0        # nhiệt độ riêng cho judge (giữ deterministic)
# LLM_COMPACT_THRESHOLD_TOKENS=100000
# LLM_COMPACT_KEEP_TURNS=3

# ── Concurrency workflow (giới hạn để bảo vệ gateway đơn) ─────────────────────
# WORKFLOW_STATIC_CONCURRENCY=3
# WORKFLOW_STATIC_GROUP_SIZE=4
# WORKFLOW_JUDGE_CONCURRENCY=3
# DISCOVERY_CONCURRENCY=8

# ── Consensus judge (điểm novelty luận văn; n=1 ⇒ judge đơn, mặc định) ────────
# CONSENSUS_N=1                  # 3–5 cho ablation self-consistency (1–9)
# CONSENSUS_RULE=weighted        # majority | weighted | unanimous-to-flag
# CONSENSUS_TEMPERATURE=0.7      # đa dạng hoá các mẫu consensus
# CONSENSUS_CONCURRENCY=3

# ── Ngưỡng / công cụ ──────────────────────────────────────────────────────────
# JUDGE_BORDERLINE_LOW=0.35      # dưới ngưỡng ⇒ có thể borderline (gọi LLM judge)
# JUDGE_BORDERLINE_HIGH=0.7      # trên ngưỡng ⇒ tự tin (heuristic chốt)
# STATIC_ENRICH=on               # opt-in: enrich exit-path analysis ở mode no_llm
# CLANG_BIN=clang                # baseline tĩnh: clang --analyze
# INFER_BIN=infer                # baseline tĩnh: Meta Infer
