# Server
PORT=8090
FRONTEND_URL=http://localhost:5173

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mcpvul
POSTGRES_PASSWORD=mcpvul
POSTGRES_DB=mcpvul

# TypeORM — set to false to use migrations instead of auto-sync
DB_SYNC=true

# JWT — CHANGE THIS in production
JWT_SECRET=mcpvul-dev-secret-change-in-production

# Analyzer transport: grpc (default) | mcp | both.
# Set to "mcp" to route control-plane↔analyzer tool calls over real MCP
# (Streamable HTTP). The analyzers must run with TRANSPORT_MODE=mcp or both.
TRANSPORT_MODE=grpc

# gRPC analyzer endpoints (used when TRANSPORT_MODE != mcp)
STATIC_ANALYZER_URL=localhost:50051
DYNAMIC_ANALYZER_URL=localhost:50052

# MCP analyzer endpoints (used when TRANSPORT_MODE=mcp)
STATIC_ANALYZER_MCP_URL=http://localhost:50061/mcp
DYNAMIC_ANALYZER_MCP_URL=http://localhost:50062/mcp

# GitHub OAuth (REQUIRED for login to work)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/login
GITHUB_CLONE_ROOT=/tmp/mcpvul/clones
SCAN_WORKSPACE_ROOT=/absolute/path/to/targets/scan-workspaces
SCAN_WORKSPACE_ANALYZER_ROOT=/workspace/targets/scan-workspaces

# Default scan mode when a request doesn't specify one (no_llm | llm_assisted)
DEFAULT_ANALYSIS_MODE=llm_assisted

# LLM judge provider (anthropic | openai | local). DEFAULT = local gateway.
JUDGE_LLM_PROVIDER=local

# --- Local OpenAI-compatible LLM gateway (default judge backend) ---
# Has its OWN key, separate from the real OpenAI API. From a Docker container
# use host.docker.internal; the gateway needs a key for non-localhost clients.
LOCAL_LLM_BASE_URL=http://host.docker.internal:20128/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=gh/gpt-5-mini
LOCAL_LLM_JSON_MODE=true

# --- Real OpenAI API (only when JUDGE_LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_JSON_MODE=true

# --- Anthropic (only when JUDGE_LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Set > 0 to enable extended thinking (e.g. 2000)
ANTHROPIC_THINKING_BUDGET=0

# --- Scan job queue (BullMQ on Redis) ---
# Scans run detached on an in-process worker so POST /api/scans returns instantly
# and long scans never drop. Redis holds the durable job queue.
REDIS_HOST=localhost
REDIS_PORT=6379
# Max scans running concurrently on the worker (also bounds LLM gateway load).
SCAN_MAX_CONCURRENCY=2
# Whole-scan job attempts (transient LLM errors are retried per-call below, so 1 is fine).
SCAN_JOB_ATTEMPTS=1
# How long a finished scan's in-memory SSE stream/history is kept before cleanup.
SCAN_STREAM_TTL_MS=600000

# --- LLM call resilience (judge) ---
JUDGE_LLM_TIMEOUT_MS=75000
JUDGE_LLM_RETRIES=2

# --- HTTP server timeouts (SSE longevity; POST is instant now) ---
HTTP_KEEPALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=70000
HTTP_REQUEST_TIMEOUT_MS=0
