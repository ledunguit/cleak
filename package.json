{
  "name": "thesis-workspace",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.ts\" \"**/*.tsx\"",
    "cleak:install": "turbo run build --filter=@cleak/cli && npm i -g ./apps/leak-inspector-tui",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "scan:smoke": "bun scripts/run-local-scan-smoke.ts",
    "eval:corpus": "bun scripts/evaluate-corpus.ts",
    "eval:compare": "bun scripts/compare-modes.ts",
    "mcp:contract": "bun scripts/mcp-contract-test.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "tsup": "^8.3.5",
    "@nestjs/cli": "^11.0.5",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.5.1",
    "turbo": "^2.5.0",
    "typescript": "~5.8.3"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/uuid": "^11.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4",
    "z3-solver": "^4.13.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
